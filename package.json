{
  "name": "@newhighsco/circleci-orb",
  "description": "New High Score shareable config for CircleCI",
  "version": "1.15.0",
  "author": "New High Score",
  "license": "ISC",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/newhighsco/circleci-orb.git"
  },
  "homepage": "https://github.com/newhighsco/circleci-orb#readme",
  "bugs": {
    "url": "https://github.com/newhighsco/circleci-orb/issues"
  },
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "prepare": "husky && brew bundle",
    "prebuild": "rm -rf dist && mkdir dist",
    "build": "circleci orb pack --skip-update-check src > dist/orb.yml",
    "pretest": "yarn lint",
    "test": "circleci orb validate --skip-update-check dist/orb.yml",
    "prelint": "yarn build",
    "lint": "concurrently 'yarn:lint:*'",
    "lint:yml": "yamllint .",
    "lint:js": "eslint --cache .",
    "format": "concurrently 'yarn:format:*'",
    "format:js": "yarn lint:js --fix"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.0",
    "@newhighsco/commitlint-config": "1.3.3",
    "@newhighsco/editor-config": "1.2.0",
    "@newhighsco/eslint-config": "7.1.18",
    "@newhighsco/lint-staged-config": "1.1.0",
    "@newhighsco/prettier-config": "2.3.11",
    "@newhighsco/release-config": "1.5.2",
    "@newhighsco/yarn-plugin-preset": "1.1.4",
    "concurrently": "10.0.3",
    "eslint": "10.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.4",
    "semantic-release": "25.0.5",
    "semantic-release-circleci-orb": "1.1.1"
  },
  "commitlint": {
    "extends": [
      "@newhighsco"
    ]
  },
  "prettier": "@newhighsco/prettier-config",
  "release": {
    "extends": "@newhighsco/release-config/orb"
  }
}
